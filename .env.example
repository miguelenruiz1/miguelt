# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=trace
POSTGRES_PASSWORD=tracepass
POSTGRES_DB=tracedb
DATABASE_URL=postgresql+asyncpg://trace:tracepass@postgres:5432/tracedb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
ARQ_REDIS_URL=redis://redis:6379/1

# ─── Solana ───────────────────────────────────────────────────────────────────
# Devnet for testing
SOLANA_RPC_URL=https://api.devnet.solana.com
# base58-encoded keypair (64 bytes) — NEVER commit real keys
# Use file path only in production: /run/secrets/solana_keypair
SOLANA_KEYPAIR=
# Set to true to skip real Solana calls (useful for local dev/tests)
SOLANA_SIMULATION=true
SOLANA_COMMITMENT=confirmed
SOLANA_TIMEOUT=30.0
# Leave empty for simulation mode
HELIUS_API_KEY=

# ─── Security ─────────────────────────────────────────────────────────────────
# Admin key for release/withdraw operations — change in production!
# Must be set — do not use a default value in production
TRACE_ADMIN_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=trace-service
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ─── Idempotency ──────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL=86400

# ─── Worker / Anchor ──────────────────────────────────────────────────────────
ANCHOR_MAX_RETRIES=5
ANCHOR_RETRY_DELAY=2.0
