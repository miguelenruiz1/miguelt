# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=trace
POSTGRES_PASSWORD=tracepass
POSTGRES_DB=tracedb
DATABASE_URL=postgresql+asyncpg://trace:tracepass@postgres:5432/tracedb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
ARQ_REDIS_URL=redis://redis:6379/1

# ─── Solana / Blockchain ──────────────────────────────────────────────────────
# SWITCH: cambia SOLANA_SIMULATION para alternar entre simulación y red real
#   true  = sin conexión a Solana (dev rápido, sin costo)
#   false = conexión real (requiere HELIUS_API_KEY + keypair con fondos)
SOLANA_SIMULATION=true
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed
SOLANA_TIMEOUT=30.0

# base58-encoded keypair (64 bytes) — fee payer para crear trees y anclar eventos
# Use file path in production: /run/secrets/solana_keypair
SOLANA_KEYPAIR=

# ─── Helius (cNFT minting + DAS API) ─────────────────────────────────────────
# Obtener gratis en https://dev.helius.xyz — plan Free = 50K requests/mes
HELIUS_API_KEY=
# Se auto-resuelve según SOLANA_NETWORK, dejar vacío salvo override
HELIUS_RPC_URL=

# ─── Security ─────────────────────────────────────────────────────────────────
# Admin key for release/withdraw operations — change in production!
# Must be set — do not use a default value in production
TRACE_ADMIN_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=trace-service
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ─── Idempotency ──────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL=86400

# ─── Worker / Anchor ──────────────────────────────────────────────────────────
ANCHOR_MAX_RETRIES=5
ANCHOR_RETRY_DELAY=2.0
