# URL base del backend (sin trailing slash)
# En dev, el proxy de Vite reenvía /api → localhost:8000, por lo que puede quedar vacío.
# En producción, pon la URL real del API:
VITE_API_URL=http://localhost:8000
VITE_USER_API_URL=http://localhost:9001
VITE_SUBSCRIPTION_API_URL=http://localhost:9002
VITE_INVENTORY_API_URL=http://localhost:9003
VITE_TENANT_ID=default
