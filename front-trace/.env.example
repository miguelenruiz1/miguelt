# URL base del gateway (sin trailing slash). Todos los servicios pasan por
# acá (ruteo en nginx) — antes había una VITE_*_API_URL por servicio pero el
# frontend las consolidó en este único endpoint.
#
# En dev: http://localhost:9000 (el gateway de compose)
# En prod: la URL del Cloud Run gateway (https://gateway-...-run.app)
VITE_API_URL=http://localhost:9000
VITE_TENANT_ID=default
