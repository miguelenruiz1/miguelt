# ═══════════════════════════════════════════════════════════════════════════════
# TRACE PLATFORM — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secrets (MUST change — generate with: openssl rand -hex 32) ──────────────
JWT_SECRET=CHANGE_ME_min_32_chars
S2S_SERVICE_TOKEN=CHANGE_ME_s2s_token
TRACE_ADMIN_KEY=CHANGE_ME_admin_key
ENCRYPTION_KEY=CHANGE_ME_32_chars_exactly_here!

# ── Database (single Cloud SQL instance, 8 databases) ────────────────────────
DB_HOST=YOUR_CLOUD_SQL_HOST
DB_PASSWORD=CHANGE_ME_db_password

TRACE_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/tracedb
USER_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/userdb
SUBSCRIPTION_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/subdb
INVENTORY_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/inventorydb
INTEGRATION_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/integrationdb
COMPLIANCE_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/compliancedb
AI_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/aidb
MEDIA_DATABASE_URL=postgresql+asyncpg://trace:${DB_PASSWORD}@${DB_HOST}:5432/mediadb

# ── Redis (single Memorystore instance) ──────────────────────────────────────
REDIS_HOST=YOUR_REDIS_HOST
REDIS_URL=redis://${REDIS_HOST}:6379

# ── Public URLs ──────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://api.trace.app
APP_URL=https://app.trace.app
FRONTEND_URL=https://app.trace.app

# ── Solana / Blockchain ──────────────────────────────────────────────────────
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR=CHANGE_ME_base58_keypair
HELIUS_API_KEY=CHANGE_ME_helius_key

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=CHANGE_ME_resend_key
SMTP_FROM=noreply@trace.app

# ── Storage (GCS or S3) ─────────────────────────────────────────────────────
STORAGE_BACKEND=s3
AWS_S3_BUCKET=trace-media-prod
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ── External APIs (optional) ────────────────────────────────────────────────
GFW_API_KEY=CHANGE_ME_gfw_key
ANTHROPIC_API_KEY=CHANGE_ME_anthropic_key

# ── App Config (usually no change needed) ────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
ACCESS_TOKEN_EXPIRE_MINUTES=480
