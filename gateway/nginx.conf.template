resolver 8.8.8.8 valid=30s;

# CORS allowlist — only echo Origin if it matches a known frontend host.
# Set $cors_origin to the trusted origin or empty string.
map $http_origin $cors_origin {
    default                                 "";
    "~^https?://localhost(:[0-9]+)?$"      $http_origin;
    "~^https?://127\.0\.0\.1(:[0-9]+)?$"   $http_origin;
    "~^https://[a-z0-9-]+\.a\.run\.app$"   $http_origin;
    "~^https://[a-z0-9-]+\.trace\.app$"    $http_origin;
}

map $uri $backend {
    # User Service
    ~^/api/v1/auth            https://${USER_UPSTREAM};
    ~^/api/v1/users           https://${USER_UPSTREAM};
    ~^/api/v1/roles           https://${USER_UPSTREAM};
    ~^/api/v1/permissions     https://${USER_UPSTREAM};
    ~^/api/v1/email           https://${USER_UPSTREAM};
    ~^/api/v1/notifications   https://${USER_UPSTREAM};
    ~^/api/v1/onboarding      https://${USER_UPSTREAM};

    # Subscription Service
    ~^/api/v1/plans           https://${SUBS_UPSTREAM};
    ~^/api/v1/subscriptions   https://${SUBS_UPSTREAM};
    ~^/api/v1/licenses        https://${SUBS_UPSTREAM};
    ~^/api/v1/modules         https://${SUBS_UPSTREAM};
    ~^/api/v1/payments        https://${SUBS_UPSTREAM};
    ~^/api/v1/platform        https://${SUBS_UPSTREAM};
    ~^/api/v1/admin           https://${SUBS_UPSTREAM};
    ~^/api/v1/usage           https://${SUBS_UPSTREAM};
    ~^/api/v1/enforcement     https://${SUBS_UPSTREAM};

    # Inventory analytics & audit (before generic inventory)
    ~^/api/v1/analytics/overview          https://${INVENTORY_UPSTREAM};
    ~^/api/v1/analytics/occupation        https://${INVENTORY_UPSTREAM};
    ~^/api/v1/analytics/abc               https://${INVENTORY_UPSTREAM};
    ~^/api/v1/analytics/eoq               https://${INVENTORY_UPSTREAM};
    ~^/api/v1/analytics/stock             https://${INVENTORY_UPSTREAM};
    ~^/api/v1/analytics/storage           https://${INVENTORY_UPSTREAM};
    ~^/api/v1/analytics/committed         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/audit                       https://${INVENTORY_UPSTREAM};

    # Inventory Service
    ~^/api/v1/categories      https://${INVENTORY_UPSTREAM};
    ~^/api/v1/products        https://${INVENTORY_UPSTREAM};
    ~^/api/v1/warehouses      https://${INVENTORY_UPSTREAM};
    ~^/api/v1/stock           https://${INVENTORY_UPSTREAM};
    ~^/api/v1/movements       https://${INVENTORY_UPSTREAM};
    ~^/api/v1/suppliers       https://${INVENTORY_UPSTREAM};
    ~^/api/v1/purchase        https://${INVENTORY_UPSTREAM};
    ~^/api/v1/sales           https://${INVENTORY_UPSTREAM};
    ~^/api/v1/customers       https://${INVENTORY_UPSTREAM};
    ~^/api/v1/partners        https://${INVENTORY_UPSTREAM};
    ~^/api/v1/customer-prices https://${INVENTORY_UPSTREAM};
    ~^/api/v1/serials         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/batches         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/recipes         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/production      https://${INVENTORY_UPSTREAM};
    ~^/api/v1/cycle           https://${INVENTORY_UPSTREAM};
    ~^/api/v1/imports         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/alerts          https://${INVENTORY_UPSTREAM};
    ~^/api/v1/portal          https://${INVENTORY_UPSTREAM};
    ~^/api/v1/reorder         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/tax             https://${INVENTORY_UPSTREAM};
    ~^/api/v1/uom             https://${INVENTORY_UPSTREAM};
    ~^/api/v1/variant         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/reports         https://${INVENTORY_UPSTREAM};
    ~^/api/v1/events          https://${INVENTORY_UPSTREAM};
    ~^/api/v1/config          https://${INVENTORY_UPSTREAM};

    # Integration Service
    ~^/api/v1/integrations    https://${INTEGRATION_UPSTREAM};
    ~^/api/v1/resolutions     https://${INTEGRATION_UPSTREAM};
    ~^/api/v1/webhooks        https://${INTEGRATION_UPSTREAM};

    # Compliance Service
    ~^/api/v1/compliance      https://${COMPLIANCE_UPSTREAM};

    # AI Service
    ~^/api/v1/analyze         https://${AI_UPSTREAM};
    ~^/api/v1/settings        https://${AI_UPSTREAM};
    ~^/api/v1/memory          https://${AI_UPSTREAM};
    ~^/api/v1/metrics         https://${AI_UPSTREAM};

    # Media Service
    ~^/api/v1/media           https://${MEDIA_UPSTREAM};

    # Trace Service (default)
    default                   https://${TRACE_UPSTREAM};
}

server {
    listen ${NGINX_PORT};
    server_name _;

    client_max_body_size 50m;

    proxy_http_version 1.1;
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Tenant-Id $http_x_tenant_id;
    # NOTE: X-User-Id is NOT proxied — it's derivable from the JWT and accepting
    # it from the client allows audit log forgery. Backends must read the user
    # id from the validated JWT token.
    proxy_set_header X-User-Id "";
    proxy_set_header Authorization $http_authorization;
    proxy_set_header Content-Type $http_content_type;
    proxy_ssl_server_name on;
    proxy_connect_timeout 10s;
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;

    # CORS — only echo Origin when it matches the allowlist (set in $cors_origin).
    # X-Service-Token is NOT in Allow-Headers because it's a S2S secret that
    # must never be sent from the browser.
    add_header Access-Control-Allow-Origin $cors_origin always;
    add_header Vary Origin always;
    add_header Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS" always;
    add_header Access-Control-Allow-Headers "Authorization,Content-Type,X-Tenant-Id,X-Correlation-Id,Idempotency-Key,X-Admin-Key,X-User-Id" always;
    add_header Access-Control-Allow-Credentials "true" always;
    add_header Access-Control-Max-Age 86400 always;

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    if ($request_method = OPTIONS) {
        return 204;
    }

    location = /health {
        return 200 '{"status":"ok","service":"gateway"}';
        add_header Content-Type application/json;
    }

    location /api/v1/ {
        proxy_pass $backend$request_uri;
    }
}
